-- Variables
local active = false
local isLoading = false
local loadTween = nil

-- Function to change speed with proper error handling
local function changeSpeed(value)
	local character = player.Character
	if not character then
		warn("No character found, waiting for respawn...")
		character = player.CharacterAdded:Wait()
	end
	
	local humanoid = character:WaitForChild("Humanoid", 5)
	if humanoid then
		humanoid.WalkSpeed = value
		print("Speed changed to: " .. value)
	else
		warn("Humanoid not found!")
	end
end

button.MouseButton1Click:Connect(function()
	if isLoading then return end
	
	if not active then
		-- START LOADING
		active = true
		isLoading = true
		status.Text = "● EXECUTING"
		status.TextColor3 = Color3.fromRGB(80,180,255)
		button.Text = "LOADING..."
		button.BackgroundColor3 = Color3.fromRGB(30,35,60)
		
		loadContainer.Visible = true
		loadingText.Visible = true
		loadingText.Text = "⚡ INITIALIZING SYSTEMS..."
		loadBar.Size = UDim2.new(0,0,1,0)
		loadPercent.Text = "0%"
		
		local connection
		connection = game:GetService("RunService").Heartbeat:Connect(function()
			if not isLoading then
				connection:Disconnect()
				return
			end
			local percent = math.floor(loadBar.Size.X.Scale * 100)
			loadPercent.Text = percent .. "%"
			
			if percent < 30 then
				loadingText.Text = "⚡ INITIALIZING SYSTEMS..."
			elseif percent < 60 then
				loadingText.Text = "🔧 CONFIGURING MODULES..."
			elseif percent < 90 then
				loadingText.Text = "🚀 CALIBRATING ENGINES..."
			else
				loadingText.Text = "✨ FINALIZING..."
			end
		end)
		
		loadTween = TweenService:Create(loadBar, TweenInfo.new(20, Enum.EasingStyle.Linear), {
			Size = UDim2.new(1,0,1,0)
		})
		
		loadTween:Play()
		
		loadTween.Completed:Connect(function()
			if active then
				isLoading = false
				
				-- CHANGE SPEED TO 50 AFTER 20s LOADING
				changeSpeed(50)
				
				status.Text = "● ACTIVE"
				status.TextColor3 = Color3.fromRGB(80,255,120)
				speed.Text = "🏃 SPEED DISPLAY  50.0"
				button.Text = "DISABLE"
				button.BackgroundColor3 = Color3.fromRGB(40,45,80)
				loadContainer.Visible = false
				loadingText.Visible = false
				
				TweenService:Create(stroke, TweenInfo.new(.3), {
					Color = Color3.fromRGB(80,255,120)
				}):Play()
				
				connection:Disconnect()
			end
		end)
		
	else
		-- DISABLE
		if loadTween then
			loadTween:Cancel()
		end
		
		active = false
		isLoading = false
		
		-- Reset speed to 16
		changeSpeed(16)
		
		status.Text = "● STANDBY"
		status.TextColor3 = Color3.fromRGB(255,200,80)
		speed.Text = "🏃 SPEED DISPLAY  16.0"
		button.Text = "ACTIVATE"
		button.BackgroundColor3 = Color3.fromRGB(40,45,80)
		loadContainer.Visible = false
		loadingText.Visible = false
		loadBar.Size = UDim2.new(0,0,1,0)
		loadPercent.Text = "0%"
		
		TweenService:Create(stroke, TweenInfo.new(.3), {
			Color = Color3.fromRGB(90,120,255)
		}):Play()
	end
end)

